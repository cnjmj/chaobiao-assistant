<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <androidx.appcompat.widget.Toolbar
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="?attr/colorPrimary"
            app:title="数据管理"
            app:titleTextColor="@android:color/white"
            app:navigationIcon="@drawable/ic_back"/>
    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 数据库备份 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="数据库备份"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#333333"/>
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="备份数据库文件并分享发送，包含所有表计和记录数据"
                        android:textSize="13sp"
                        android:textColor="#888888"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="12dp"/>
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_backup_db"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="备份数据库"
                        app:icon="@android:drawable/ic_menu_save"
                        app:backgroundTint="#009688"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 数据库恢复 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="数据库恢复"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#333333"/>
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="从备份文件恢复数据库，当前数据将被替换（不可撤销）"
                        android:textSize="13sp"
                        android:textColor="#888888"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="12dp"/>
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_restore_db"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="恢复数据库"
                        app:icon="@android:drawable/ic_menu_upload"
                        app:backgroundTint="#FF7043"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- CSV导出 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="CSV导出"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#333333"/>
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="导出所有表计和记录数据为CSV文件并分享，可用Excel打开"
                        android:textSize="13sp"
                        android:textColor="#888888"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="12dp"/>
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_export_csv"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="导出CSV"
                        app:icon="@android:drawable/ic_menu_share"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:textColor="#1976D2"
                        app:strokeColor="#1976D2"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- CSV导入 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="CSV导入"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#333333"/>
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="从CSV文件导入表计和记录数据，追加到当前数据（需本APP导出格式）"
                        android:textSize="13sp"
                        android:textColor="#888888"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="12dp"/>
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_import_csv"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="导入CSV"
                        app:icon="@android:drawable/ic_menu_upload"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:textColor="#FF7043"
                        app:strokeColor="#FF7043"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 数据统计概览 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="数据概览"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#333333"
                        android:layout_marginBottom="8dp"/>
                    <TextView
                        android:id="@+id/tv_data_summary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="加载中..."
                        android:textSize="14sp"
                        android:textColor="#666666"
                        android:lineSpacingExtra="4dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
